# ============================================================================
# Cloudflare SRV record for the Minecraft server
# ============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# DO NOT commit terraform.tfvars to version control — it holds an API token.
# ============================================================================

# Cloudflare API token with Zone:DNS:Edit on the target zone.
# Create one at: https://dash.cloudflare.com/profile/api-tokens
# Or export it as TF_VAR_cloudflare_api_token to keep it out of files entirely.
cloudflare_api_token = "your-api-token-here"

# Zone ID for the domain you're adding records to.
# Find at: https://dash.cloudflare.com → select domain → Overview → right sidebar.
zone_id = "your-zone-id-here"

# Apex domain you own (no protocol, no path).
domain = "example.com"

# Subdomain for the Minecraft server. Final hostname = <subdomain>.<domain>.
subdomain = "mc"

# Public IPv4 of your home — what your ISP assigns to the router.
# Find via:  curl -4 ifconfig.me
server_ip = "203.0.113.42"

# Port your router forwards externally to the Minecraft container's 25565.
# Defaults to 25565 if you omit this.
# minecraft_port = 25565
