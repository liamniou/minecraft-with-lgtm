# Copy to `.env` and fill in real values. `.env` is git-ignored.

# Discord webhook for Grafana alerts (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE/ME

# Repo Doco-CD polls (Stage 5).
DOCO_CD_REPO_URL=https://github.com/liamniou/minecraft-with-lgtm.git
# DOCO_CD_REPO_REF=main

# Optional GitHub PAT — avoids public-clone rate limits. Fine-grained, read-only Contents on this repo.
GIT_ACCESS_TOKEN=
